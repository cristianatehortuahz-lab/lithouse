div.rowDepartment{
    max-width: 1280px;
    margin: auto;
    padding-left: 20px;
}

#generalDeparment{
    position: relative;
    width: 100%;
    padding: 1px 1px 1px 1px;
    margin: 1px 1px 1px 1px;
    display: inline-flex;
}

#identityDeparment{
    position: relative;
    width: 30%;
    padding: 1px 1px 1px 1px;
    margin: 1px 1px 1px 1px;
    display: inline-grid;
    align-content: baseline;
}

#principalDeparment{
    position: relative;
    width: 70%;
    padding: 1px 1px 1px 1px;
    margin: 1px 1px 1px 1px;
    display: inline-grid;
    align-content: baseline;
}

section#ADphotoOrganization img.individual-photo
{
    width: 320px;
    margin-left: 0;
    margin: 2px 2px 2px 2px;
}
#keyWordsDeparment{
    position: relative;
    width: 100%;
    padding: 1px 1px 1px 1px;
    margin: 1px 1px 1px 1px;
    display: inline-flex;
}

#shortViewDeparmentPeople{
    position: relative;
    width: 100%;
    padding: 1px 1px 1px 1px;
    margin: 1px 1px 1px 1px;
    /* display: inline-flex; */
}

#ADphotoOrganization{
    position: relative;
    display: block;
    width: auto;
    padding: 1px 1px 1px 1px;
    margin: 1px 1px 1px 1px;
    display: flex;
    justify-content: center;
}

#SearchGroupDeparment{
    position: relative;
    display: block;
    width: auto;
    padding: 1px 1px 1px 1px;
    margin: 1px 1px 1px 1px;
}

#ADindividualOverview{
    position: relative;
    display: block;
    width: auto;
    padding: 1px 1px 1px 1px;
    margin: 1px 1px 1px 1px;
    text-align: justify;
}
#ADpaginaWEB{    
    position: relative;
    display: block;
    width: auto;
    padding: 1px 1px 1px 1px;
    margin: 1px 1px 1px 1px;

}

#ADkeywords{
    padding: 1px 1px 1px 1px;
    margin: 1px 1px 1px 1px;
}
#ADindividualPersonAdmin{
    padding: 1px 1px 1px 1px;
    margin: 1px 1px 1px 1px;
    display: flex;
    justify-content: space-around;
}
#ADindividualPersonProfesor{
    padding: 1px 1px 1px 1px;
    margin: 1px 1px 1px 1px;
}

#principalDeparment h1 {
    color: #5E6363;
    font-size: 35px;
    font-weight: bold;
    text-transform: uppercase;
}


#ADindividualPersonAdmin li.col-lg-3, li.col-md-4, li.col-sm-6{
    padding: 1px 1px 1px 1px;
    margin: 0px 0px 10px 0px;
    list-style-type: none;
    width: 30%;
    border: none;
}
.card {
    border: none !important;
}


#ADindividualPersonProfesor li.col-lg-2, li.col-md-3, li.col-sm-4{
    margin: auto;
    padding: 1px 6px 1px 6px;
    margin: 0px 0px 10px 0px;
    overflow: hidden;
    list-style-type: none;
    display: inline-flex;
}

#ADindividualPersonAdmin .card-img-top, #ADindividualPersonProfesor .card-img-top{
    width: 160px !important;
    margin: auto;
    height: 180px;
    border: 3px solid #d4bab8a1;
    display: flex;
    
}

 

#ADindividualPersonAdmin li div div.card-body, #ADindividualPersonProfesor li div div.card-body{
    font-size: 10px;
    padding: 0% 1% 0% 1%;
    margin: 0% 1% 0% 1%;
    color: #0039AD;
    
}

#ADindividualPersonAdmin li div div h5.card-title, #ADindividualPersonProfesor li div div h5.card-title{
    font-size: 11px;
    padding: 0% 1% 0% 1%;
    margin: 0% 1% 0% 1%;
    color: #0039AD;
    overflow: hidden;
    text-overflow: ellipsis;
    text-align: center;
}

#ADindividualPersonAdmin li div div h5.card-title a, #ADindividualPersonProfesor li div div h5.card-title a{
    font-size: 11px;
    padding: 0% 1% 0% 1%;
    margin: 0% 1% 0% 1%;
    color: #0039AD;
    text-align: center;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-decoration: none;
}
#ADindividualPersonAdmin li div div h5.card-title a:hover, #ADindividualPersonProfesor li div div h5.card-title a:hover{
    color: #8b1919;
}

.organizationInf hr{
    margin-top: 13px;
    margin-bottom: 10px;
    border: 0;
    border-top: 4px solid #145da0;
}


div.vcard-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  justify-content: flex-start;
}

div.vcard {
  background-color: #e9f1ff;
  border: 1px solid #c6d7f0;
  border-radius: 10px;
  width: 190px;
  height: 50px;
  padding: 0px;
  box-sizing: border-box;
  text-align: center;
  font-family: sans-serif;
  display: flex;
  flex-direction: column;
  justify-content: center;
  box-shadow: 1px 2px 5px rgba(0, 0, 0, 0.05);
}


ul#individual-hasResearchGroup{
    display: inline-flex;
    margin: auto;
    padding: 0;
    flex-wrap: wrap;
}


ul#individual-hasResearchGroup a.raLink{
    font-size: 11px;
     text-align: center;
    line-height: 1;
}


#SearchGroupDeparment li.col-lg-2, li.col-md-3, li.col-sm-4 {
    padding: 1px 1px 1px 1px;
    margin: 0px 7px 5px 7px;
    overflow: hidden;
    list-style-type: none;
    width: auto;
}


#ADpaginaWEB ul.individual-urls {
    list-style: none; /* Quitar estilo por defecto */
    margin-bottom: 5px;
}

#ADpaginaWEB ul.individual-urls li::before{
    content: "";
    display: inline-block;
    background-image: url(../images/logos/logoWEB.png);
    background-size: 16px 16px; /* Cambia el tamaño aquí */
    background-repeat: no-repeat;
    width: 16px;
    height: 16px;
    vertical-align: middle;
    margin: 1px 2px 1px 1px;
}

#ADContact ul {
    list-style: none; /* Quitar estilo por defecto */
    margin-bottom: 0px;
}

section#ADSearchGroup h2#facultyResearchAreas {
    clear: left;
    padding-bottom: 3px;
    padding-top: 1px;
}

#ADContact ul li::before{
    content: "";
    display: inline-block;
    background-image: url(../images/logos/iconoPhone.png);
    background-size: 14px 24px;
    background-repeat: no-repeat;
    width: 20px;
    height: 23px;
    vertical-align: middle;
    margin: 1px 1px 1px 4px;
}

#ADContact ul li{
    display: inline-flex;
}

#ADContact ul li h1{
    display: flex;
    font-size: 16px;
    margin-top: 4px;
}

ul.individual-urls li a{
    font-size: 16px;
    line-height: 1em;
}

div.imagenes{
    width: 160px !important;
    margin: auto;
    height: 180px;
    border: 3px solid #d4bab8a1;
    display: flex;
}


/* Scroll de perfiles de investigadores en deparment */

.scroll-container {
    max-height: 57vh; /* o un valor fijo como 600px */
    overflow-y: auto;
    scroll-snap-type: y mandatory;
    border: 2px solid #ccc;
    padding: 1rem;
    border-radius: 10px;
}

/* Estilo de cada card item */
.scroll-container li {
    list-style: none;
    scroll-snap-align: start;
}

/* Opcional: mejora visual del scroll */
.scroll-container::-webkit-scrollbar {
    width: 8px;
}
.scroll-container::-webkit-scrollbar-thumb {
    background-color: #999;
    border-radius: 5px;
}

div.imagenes a img{
    width: 20px;
    height: 20px;
    position: absolute;
    left: 128px;
    top: 112px;
}
ul{
    margin: 0px;
    padding-bottom: 0px;
}

div.imagenes a img:hover{
    width: 25px;
    height: 25px;
}


/* cards individuals*/
/* Contenedor principal de las tarjetas */
.scroll-container {
  display: flex;
  flex-wrap: wrap; /* Permite que las tarjetas se envuelvan a la siguiente línea */
  gap: 20px; /* Espacio entre las tarjetas */
  justify-content: center; /* Centra las tarjetas en el contenedor principal */
}

/* Estilo para cada elemento de la lista (li) */
.adLink {
  list-style: none; /* Elimina los puntos de la lista */
  display: flex;
  flex-direction: column;
  align-items: center; /* Centra el contenido verticalmente en el li */
  text-align: center; /* Centra el texto */
  width: 250px; /* Ancho fijo para todas las tarjetas */
  height: 350px; /* Altura fija para todas las tarjetas */
  box-sizing: border-box; /* Asegura que el padding y el border no afecten el tamaño total */
}

/* Estilo para la tarjeta en sí */
.card {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between; /* Distribuye el espacio entre la imagen y el texto */
  border: 1px solid #ccc;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease-in-out;
}

.card:hover {
  transform: translateY(-5px);
}

/* Contenedor de la imagen */
.imagenes {
  width: 100%;
  height: 60%; /* Ajusta la altura del contenedor de la imagen */
  display: flex;
  justify-content: center; /* Centra la imagen horizontalmente */
  align-items: center; /* Centra la imagen verticalmente */
  padding: 10px;
  position: relative;
}

/* Estilo para la imagen dentro del contenedor */
.card-img-top {
  max-width: 100%;
  max-height: 100%;
  object-fit: cover; /* Recorta la imagen para que cubra el espacio sin distorsionarse */
  border-radius: 8px;
}

/* Contenedor del cuerpo de la tarjeta (texto) */
.card-body {
  padding: 10px;
  text-align: center; /* Centra el texto en el cuerpo de la tarjeta */
  flex-grow: 1; /* Permite que el cuerpo de la tarjeta ocupe el espacio restante */
  display: flex;
  flex-direction: column;
  justify-content: center; /* Centra el texto verticalmente en su contenedor */
}

/* Estilo para los títulos de la tarjeta */
.card-title {
  font-size: 1rem;
  margin-bottom: 5px;
}

.card-title a {
  text-decoration: none;
  color: #333;
}

/* Estilos responsivos para diferentes tamaños de pantalla */
@media (max-width: 992px) {
  .adLink {
    width: 300px; /* Aumenta el ancho de las tarjetas en pantallas medianas */
  }
}

@media (max-width: 768px) {
  .adLink {
    width: 45%; /* Ancho para dos columnas en pantallas pequeñas */
  }
}

@media (max-width: 576px) {
  .adLink {
    width: 90%; /* Ancho completo para una sola columna en pantallas extra pequeñas */
  }
}

/* fin cards individuals*/