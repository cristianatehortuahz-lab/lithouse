<script>
    (function($, w) {
        var ran = false;
        var runTasks = function() {
            if (ran) return;
            var queue = w.jQueryQueue || w.jQueryQuere || [];
            if (queue.length === 0) return;
            ran = true;
            console.log("HUB-UR: Ejecutando Motor de Prioridad v2.5 (Tareas: " + queue.length + ")");
            
            // 1. Separar tareas prioritarias (Dashboard)
            var priority = [];
            var regular = [];
            queue.forEach(function(item) {
                var s = (typeof item === 'function') ? item.toString() : "";
                if (s.indexOf('individual') !== -1 || s.indexOf('ListProp') !== -1) priority.push(item);
                else regular.push(item);
            });
            
            // 2. Ejecutar
            priority.concat(regular).forEach(function(item) {
                try {
                    if (typeof item === 'function') { item($); }
                    else if (item.selector && item.calls) {
                        var el = $(item.selector);
                        if(el.length > 0) {
                            item.calls.forEach(function(c) {
                                if (typeof el[c.m] === 'function') { el = el[c.m].apply(el, c.a); }
                            });
                        }
                    }
                } catch(e) { console.warn("HUB-UR: Error en script diferido", e); }
            });

            // 3. Ordenaci\u00f3n Especial Comunidad UR (Ejecuci\u00f3n \u00fanica)
            setTimeout(function() {
                var ul = document.getElementById("milista");
                if (ul) {
                    var items = Array.from(ul.querySelectorAll("li.hub-person-item, li.col-lg-3"));
                    if (items.length > 0) {
                        items.sort(function(a, b) {
                            var elA = a.querySelector("h5 a") || a.querySelector("a");
                            var elB = b.querySelector("h5 a") || b.querySelector("a");
                            var nA = elA ? elA.textContent.trim() : "";
                            var nB = elB ? elB.textContent.trim() : "";
                            return nA.localeCompare(nB);
                        });
                        ul.innerHTML = "";
                        items.forEach(function(item) { ul.appendChild(item); });
                        ul.style.opacity = "1";
                    }
                }
            }, 200);
        };
        $(document).ready(runTasks);
        $(window).on('load', runTasks);
    })(jQuery, window);
</script>
